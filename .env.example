# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key — the only key needed to run a review locally.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Optional (have sensible defaults) ───────────────────────────────────────

# Override the review model. Defaults to "claude-opus-4-7".
# ANTHROPIC_MODEL=claude-opus-4-7

# Reasoning effort: low | medium | high | xhigh | max. Defaults to "high".
# Higher = better recall, more tokens/cost.
# ANTHROPIC_EFFORT=high

# ─── GitHub PR review ────────────────────────────────────────────────────────
#
# There is intentionally NO server-side GitHub token. Public PRs are fetched
# anonymously; for a private repo, the user supplies their own token in the UI,
# which is used only to fetch that diff and is never stored, logged, or sent to
# the model. So nothing to configure here.

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
#
# Required in production so per-IP limits and the global daily cap are enforced
# across Vercel's serverless instances. Create a free DB at https://upstash.com/.
# Without these, a dev-only in-memory fallback is used — per-instance and NOT
# safe to rely on in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Limits (optional; defaults shown). The global cap smooths spend under your
# Anthropic Console monthly limit — set that Console limit too; it's the hard cap.
# RATE_LIMIT_PER_MINUTE=1
# RATE_LIMIT_PER_DAY=5
# DAILY_REVIEW_CAP=20

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
#
# Postgres connection string for user accounts, subscriptions, and usage.
# Create a free project at https://neon.tech/ and paste its pooled connection
# string. Then run `npm run db:migrate` to apply the schema.
DATABASE_URL=

# ─── Auth (Auth.js v5 — Google + GitHub) ─────────────────────────────────────
#
# Session-signing secret. Generate with: npx auth secret  (or openssl rand -base64 33)
AUTH_SECRET=

# GitHub OAuth app: https://github.com/settings/developers
# Authorization callback URL: <origin>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth client (Web): https://console.cloud.google.com/ (APIs & Services → Credentials)
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Canonical URL in production (e.g. https://your-app.vercel.app). Auto-detected locally.
# AUTH_URL=

# ─── Payments (Stripe — test mode) ───────────────────────────────────────────
#
# Create two recurring (monthly) prices in the Stripe Dashboard — one for Lite,
# one for Pro — and paste their price ids below. https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_PRICE_LITE=
STRIPE_PRICE_PRO=

# Webhook signing secret. Locally, run:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# and copy the whsec_… it prints. In production, use the dashboard webhook's secret.
STRIPE_WEBHOOK_SECRET=
